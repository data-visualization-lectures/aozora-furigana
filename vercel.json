{
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "aozora-furigana.dataviz.jp" }],
      "destination": "https://aozora-furigana.dataprep.jp/:path*",
      "permanent": true
    }
  ],
  "builds": [
    { "src": "api/convert.py", "use": "@vercel/python" },
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "static/**/*", "use": "@vercel/static" }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "has": [{ "type": "host", "value": "aozora-furigana.dataviz.jp" }],
      "status": 308,
      "headers": { "Location": "https://aozora-furigana.dataprep.jp/$1" }
    },
    { "src": "/api/convert", "dest": "api/convert.py" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
